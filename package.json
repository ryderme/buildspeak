{
  "name": "buildspeak",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "pipeline": "pnpm --filter @buildspeak/pipeline run start",
    "fetch-feed": "pnpm --filter @buildspeak/pipeline run fetch",
    "daily": "pnpm fetch-feed && pnpm pipeline"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22"
  }
}
