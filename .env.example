# Translation API (OpenAI-compatible Chat Completions)
# Used by packages/pipeline at build time only — never shipped to client
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# PostHog — pipeline (server-side, posthog-node). Project API key (phc_…).
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://us.i.posthog.com

# PostHog — web (browser-side, posthog-js). Same value as POSTHOG_API_KEY but
# exposed to the client bundle via NEXT_PUBLIC_ prefix. The phc_… key is safe
# to ship to the browser; the personal API key (phx_…) is not used by the app.
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
